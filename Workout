<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QA Workout | Elite Editor MTD</title>
  <link href="https://googleapis.com" rel="stylesheet">
  <style>
    :root { --primary: #f59e0b; --navy: #0f172a; --slate: #1e293b; --bg: #fef3c7; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); margin: 0; display: flex; height: 100vh; overflow: hidden; }

    /* EXACT SIDEBAR STYLE MATCHED TO YOUR ADMIN PANEL */
    .sidebar { width: 280px; background: var(--navy); color: white; display: flex; flex-direction: column; border-right: 2px solid var(--primary); }
    .sidebar-header { padding: 25px; border-bottom: 1px solid var(--slate); text-align: center; }
    .day-list { flex: 1; overflow-y: auto; padding: 10px; }
    
    .day-item { padding: 15px; margin-bottom: 8px; border-radius: 12px; cursor: pointer; transition: 0.3s; color: #94a3b8; font-weight: 700; display: flex; align-items: center; gap: 10px; }
    .day-item:hover { background: var(--slate); color: white; }
    .day-item.active { background: var(--primary); color: var(--navy); font-weight: 800; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2); }

    /* MAIN CONTENT VIEWPORT */
    .editor-main { flex: 1; display: flex; flex-direction: column; background: white; }
    .editor-header { padding: 20px 40px; background: white; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; }
    .scroll-content { padding: 40px; overflow-y: auto; flex: 1; background: #f8fafc; }
    
    /* WORKOUT COMPONENT CARD DESIGN */
    .card { background: white; padding: 25px; border-radius: 20px; margin-bottom: 25px; border: 1px solid #e2e8f0; border-left: 5px solid var(--primary); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
    .card-meta { margin-bottom: 12px; }
    .exercise-header { font-size: 16px; font-weight: 800; color: var(--navy); }
    .exercise-sub { font-size: 12px; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; display: inline-block; }
    
    /* METRICS TABLE ROWS */
    .row { display: flex; flex-direction: column; margin-top: 8px; background: #f8fafc; padding: 12px 15px; border-radius: 12px; border: 1px solid #e2e8f0; transition: all 0.2s ease; }
    .row.done { background: rgba(34, 197, 94, 0.08); border-color: rgba(34, 197, 94, 0.25); }
    .row-main { display: flex; justify-content: space-between; align-items: center; width: 100%; }
    .row-main span { font-size: 13px; font-weight: 800; color: var(--navy); width: 35px; }
    .rec-reps { font-size: 10px; color: var(--primary); font-weight: 800; background: rgba(245, 158, 11, 0.1); padding: 2px 6px; border-radius: 5px; margin-left: 5px; border: 1px solid rgba(245, 158, 11, 0.15); }
    
    .inputs { display: flex; align-items: center; gap: 10px; }
    .input-group { display: flex; align-items: center; background: white; border: 2px solid #e2e8f0; border-radius: 8px; padding: 2px 8px; }
    input[type="number"] { width: 45px; padding: 4px 2px; text-align: center; background: transparent; color: var(--navy); border: none; font-size: 14px; font-weight: 700; font-family: inherit; }
    input[type="number"]:focus { outline: none; }
    .unit { font-size: 9px; color: #94a3b8; font-weight: 800; text-transform: uppercase; }
    .history-text { font-size: 11px; color: #64748b; margin-top: 6px; font-style: italic; display: block; border-top: 1px dashed #e2e8f0; padding-top: 4px; }
    
    /* CUSTOM ELITE CHECKBOX STYLING */
    .checkbox-container { display: block; position: relative; width: 22px; height: 22px; cursor: pointer; }
    .checkbox-container input { position: absolute; opacity: 0; cursor: pointer; height: 0; width: 0; }
    .checkmark { position: absolute; top: 0; left: 0; height: 22px; width: 22px; background-color: white; border: 2px solid #cbd5e1; border-radius: 6px; transition: 0.2s; }
    .checkbox-container:hover input ~ .checkmark { border-color: var(--primary); }
    .checkbox-container input:checked ~ .checkmark { background-color: #22c55e; border-color: #22c55e; }
    .checkmark:after { content: ""; position: absolute; display: none; left: 7px; top: 3px; width: 5px; height: 9px; border: solid white; border-width: 0 2.5px 2.5px 0; transform: rotate(45deg); }
    .checkbox-container input:checked ~ .checkmark:after { display: block; }
    
    /* STATUS INDICATOR TEXT */
    .autosave-badge { font-size: 11px; color: #22c55e; font-weight: 800; display: flex; align-items: center; gap: 4px; background: rgba(34, 197, 94, 0.1); padding: 4px 10px; border-radius: 20px; border: 1px solid rgba(34, 197, 94, 0.2); }
  </style>
</head>
<body>

  <!-- SIDEBAR SYSTEM FROM YOUR TEMPLATE (AUTO SAVED MODE) -->
  <div class="sidebar">
    <div class="sidebar-header"><h2 style="color:var(--primary); font-size:0.9rem; font-weight: 800; letter-spacing: 0.5px;">QA WORKOUT LOG</h2></div>
    <div class="day-list">
        <div id="tab-lunes" class="day-item active" onclick="switchTab('lunes')">🏋️ MONDAY (A)</div>
        <div id="tab-miyerkules" class="day-item" onclick="switchTab('miyerkules')">🏋️ WEDNESDAY (B)</div>
        <div id="tab-biyernes" class="day-item" onclick="switchTab('biyernes')">🏋️ FRIDAY (C)</div>
    </div>
    <div style="padding: 20px; text-align: center; display: flex; justify-content: center;">
         <div class="autosave-badge">🟢 Cloud Auto-Save Active</div>
    </div>
  </div>

  <div class="editor-main">
    <div class="editor-header">
      <h2 style="color:var(--navy); font-size: 1.1rem; font-weight: 800;">Workout Plan Tracker</h2>
    </div>
    
    <div class="scroll-content">
      <form id="trackerForm">
          <!-- MONDAY VIEW SECTION -->
          <div id="lunes" class="content active">
              <div class="card"><div class="card-meta"><div class="exercise-header">Barbell Squats</div><span class="exercise-sub">Legs Quadriceps</span></div><div id="s-squat"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Leg Extensions</div><span class="exercise-sub">Quads Isolation Finisher</span></div><div id="s-legext"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Flat Bench Press</div><span class="exercise-sub">Chest Pectorals Mass</span></div><div id="s-bench"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Barbell Rows</div><span class="exercise-sub">Latissimus Dorsi / Back</span></div><div id="s-rows"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Overhead Press</div><span class="exercise-sub">Deltoids Shoulder Width</span></div><div id="s-ohp"></div></div>
          </div>

          <!-- WEDNESDAY VIEW SECTION -->
          <div id="miyerkules" class="content">
              <div class="card"><div class="card-meta"><div class="exercise-header">Conventional Deadlifts</div><span class="exercise-sub">Posterior Chain Strength</span></div><div id="s-dl"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Leg Curls</div><span class="exercise-sub">Hamstrings Isolation Finisher</span></div><div id="s-legcurl"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Incline Dumbbell Press</div><span class="exercise-sub">Upper Pectorals mass</span></div><div id="s-inc"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Lat Pulldowns</div><span class="exercise-sub">Back Width Structure</span></div><div id="s-lat"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Side Lateral Raises</div><span class="exercise-sub">Side Deltoids Isolation</span></div><div id="s-latr"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Barbell Bicep Curls</div><span class="exercise-sub">Biceps Peak Expansion</span></div><div id="s-bi"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Skull Crushers</div><span class="exercise-sub">Triceps Lateral Mass</span></div><div id="s-tri"></div></div>
          </div>

          <!-- FRIDAY VIEW SECTION -->
          <div id="biyernes" class="content">
              <div class="card"><div class="card-meta"><div class="exercise-header">Leg Press</div><span class="exercise-sub">Legs Thickness Hypertrophy</span></div><div id="s-lp"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Dumbbell Shoulder Press</div><span class="exercise-sub">Anterior Deltoids Mass</span></div><div id="s-sp"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Seated Cable Rows</div><span class="exercise-sub">Mid Back Depth Growth</span></div><div id="s-cr"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Dumbbell Hammer Curls</div><span class="exercise-sub">Brachioradialis / Forearms</span></div><div id="s-hc"></div></div>
              <div class="card"><div class="card-meta"><div class="exercise-header">Weighted Dips / Pushdowns</div><span class="exercise-sub">Lower Chest / Triceps</span></div><div id="s-dp"></div></div>
          </div>
      </form>
    </div>
  </div>
  <script>
    let db = {};
    
    const mondayEx = { 'squat': {s:4, r:'6-8 reps'}, 'legext': {s:3, r:'12 reps'}, 'bench': {s:4, r:'6-8 reps'}, 'rows': {s:4, r:'6-8 reps'}, 'ohp': {s:3, r:'8 reps'} };
    const wednesdayEx = { 'dl': {s:3, r:'5 reps'}, 'legcurl': {s:3, r:'12 reps'}, 'inc': {s:4, r:'8 reps'}, 'lat': {s:4, r:'8 reps'}, 'latr': {s:3, r:'10-12 reps'}, 'bi': {s:3, r:'8-10 reps'}, 'tri': {s:3, r:'8-10 reps'} };
    const fridayEx = { 'lp': {s:4, r:'8 reps'}, 'sp': {s:4, r:'8 reps'}, 'cr': {s:4, r:'8 reps'}, 'hc': {s:3, r:'10 reps'}, 'dp': {s:3, r:'10 reps'} };

    function generateInputs(exList, prefix) {
      Object.keys(exList).forEach(k => {
        let h = '';
        for(let i=1; i<=exList[k].s; i++) {
          h += `<div class="row" id="${prefix}-${k}-row-${i}">
                  <div class="row-main">
                    <div>
                      <span>S${i}</span>
                      <span class="rec-reps">🎯 ${exList[k].r}</span>
                    </div>
                    <div class="inputs">
                      <div class="input-group">
                        <input type="number" id="${prefix}-${k}-w-${i}" oninput="autoSaveVal('${prefix}-${k}-w-${i}', this.value)" placeholder="0">
                        <span class="unit">kg</span>
                      </div>
                      <div class="input-group">
                        <input type="number" id="${prefix}-${k}-r-${i}" oninput="autoSaveVal('${prefix}-${k}-r-${i}', this.value)" placeholder="0">
                        <span class="unit">reps</span>
                      </div>
                      <label class="checkbox-container">
                        <input type="checkbox" id="${prefix}-${k}-c-${i}" onchange="autoSaveCb('${prefix}-${k}-c-${i}', this.checked); toggleRowBackground('${prefix}-${k}-row-${i}','${prefix}-${k}-c-${i}')">
                        <span class="checkmark"></span>
                      </label>
                    </div>
                  </div>
                  <span class="history-text" id="${prefix}-${k}-h-${i}">Last session: -- kg x -- reps</span>
                </div>`;
        }
        if(document.getElementById(`s-${k}`)) document.getElementById(`s-${k}`).innerHTML = h;
      });
    }

    generateInputs(mondayEx, 'l'); generateInputs(wednesdayEx, 'm'); generateInputs(fridayEx, 'b');

    window.addEventListener('DOMContentLoaded', () => {
      const savedData = localStorage.getItem('qa_workout_v3_data');
      if (savedData) { 
        db = JSON.parse(savedData); applyFormValues(); 
      } else {
        document.querySelectorAll('#trackerForm input').forEach(i => {
            db[i.id] = i.type === 'checkbox' ? false : "";
        });
        localStorage.setItem('qa_workout_v3_data', JSON.stringify(db));
        applyFormValues();
      }
    });

    // 🔄 REAL-TIME AUTO-SAVE LOGIC ENGINE (SAME OPERATIONAL LOGIC AS YOUR TEMPLATE)
    function autoSaveVal(id, val) { 
      db[id] = val; 
      if(val) { db[id + '-hist'] = val; } 
      localStorage.setItem('qa_workout_v3_data', JSON.stringify(db));
      renderHistoryLabels();
    }

    function autoSaveCb(id, val) { 
      db[id] = val; 
      localStorage.setItem('qa_workout_v3_data', JSON.stringify(db));
    }

    function applyFormValues() {
      document.querySelectorAll('#trackerForm input').forEach(i => { 
        if(db[i.id] !== undefined) {
          if(i.type === 'checkbox') {
            i.checked = (db[i.id] === true || db[i.id] === 'true');
            const rowId = i.id.replace('-c-', '-row-');
            if(i.checked && document.getElementById(rowId)) document.getElementById(rowId).classList.add('done');
          } else { i.value = db[i.id]; }
        }
      });
      renderHistoryLabels();
    }

    function renderHistoryLabels() {
      const prefixes = ['l', 'm', 'b']; const lists = [mondayEx, wednesdayEx, fridayEx];
      prefixes.forEach((prefix, listIdx) => {
        Object.keys(lists[listIdx]).forEach(k => {
          for(let i=1; i<=lists[listIdx][k].s; i++) {
            const histLabel = document.getElementById(`${prefix}-${k}-h-${i}`);
            if (histLabel) {
              const lastWt = db[`${prefix}-${k}-w-${i}-hist`] || '--';
              const lastReps = db[`${prefix}-${k}-r-${i}-hist`] || '--';
              histLabel.innerText = `Last session: ${lastWt} kg x ${lastReps} reps`;
            }
          }
        });
      });
    }

    function switchTab(dayId) {
      document.querySelectorAll('.content').forEach(c => c.classList.remove('active'));
      document.querySelectorAll('.day-item').forEach(b => b.classList.remove('active'));
      document.getElementById(dayId).classList.add('active'); 
      document.getElementById('tab-' + dayId).classList.add('active');
    }

    function toggleRowBackground(rowId, cbId) {
      const row = document.getElementById(rowId); const cb = document.getElementById(cbId);
      if (row && cb) cb.checked ? row.classList.add('done') : row.classList.remove('done');
    }
  </script>
</body>
</html>
